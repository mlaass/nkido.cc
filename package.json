{
  "name": "nkido.cc",
  "version": "0.0.1",
  "type": "module",
  "private": true,
  "scripts": {
    "predev": "bun run scripts/fetch-mirrored-docs.ts",
    "dev": "vite dev",
    "prebuild": "bun run scripts/fetch-mirrored-docs.ts && bun run scripts/validate-frontmatter.ts",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && bun run scripts/fetch-mirrored-docs.ts && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch"
  },
  "devDependencies": {
    "@sveltejs/adapter-static": "^3.0.0",
    "@sveltejs/kit": "^2.0.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "gray-matter": "^4.0.3",
    "mdsvex": "^0.12.7",
    "rehype-slug": "^6.0.0",
    "shiki": "^4.0.2",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "typescript": "^5.0.0",
    "vite": "^6.0.0"
  },
  "dependencies": {
    "lucide-svelte": "^0.469.0"
  }
}